def extract_kaggle_archives(input_root=KAGGLE_INPUT, extract_root=EXTRACT_ROOT):
    extracted_dirs = []
    if not input_root.exists():
        return extracted_dirs

    extract_root.mkdir(parents=True, exist_ok=True)
    zip_files = sorted([p for p in input_root.rglob('*.zip') if p.is_file()])
    if not zip_files:
        return extracted_dirs

    print(f'Found {len(zip_files)} zip file(s) in {input_root}.')
    for zf in zip_files:
        target_dir = extract_root / zf.stem
        marker = target_dir / '.unzipped.ok'
        if marker.exists() and target_dir.exists():
            print(f'Already extracted: {zf} -> {target_dir}')
            extracted_dirs.append(target_dir)
            continue

        target_dir.mkdir(parents=True, exist_ok=True)
        print(f'Extracting: {zf} -> {target_dir}')
        with zipfile.ZipFile(zf, 'r') as archive:
            archive.extractall(target_dir)
        marker.write_text('ok')
        extracted_dirs.append(target_dir)

    return extracted_dirs

EXTRACTED_DIRS = extract_kaggle_archives()

def _search_roots():
    roots = [ROOT, KAGGLE_WORKING]
    if KAGGLE_INPUT.exists():
        roots.append(KAGGLE_INPUT)
    roots.extend(EXTRACTED_DIRS)
    # Preserve order while removing duplicates
    return list(dict.fromkeys([p for p in roots if p.exists()]))

SEARCH_ROOTS = _search_roots()

def resolve_dir(dir_name):
    candidates = []
    for base in SEARCH_ROOTS:
        candidates.append(base / dir_name)
        candidates.extend(p for p in base.rglob(dir_name) if p.is_dir())
    for p in candidates:
        if p.exists() and p.is_dir():
            return p
    searched = ', '.join(str(p) for p in SEARCH_ROOTS)
    raise FileNotFoundError(f'Could not find directory: {dir_name}. Searched in: {searched}')

def resolve_file(filename):
    candidates = []
    for base in SEARCH_ROOTS:
        candidates.append(base / filename)
        candidates.extend(p for p in base.rglob(filename) if p.is_file())
    for p in candidates:
        if p.exists() and p.is_file():
            return p
    searched = ', '.join(str(p) for p in SEARCH_ROOTS)
    raise FileNotFoundError(f'Could not find file: {filename}. Searched in: {searched}')

