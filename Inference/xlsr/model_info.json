{
  "model": "BanglaDeepfakeDetector",
  "architecture": {
    "frontend": "facebook/wav2vec2-xls-r-300m",
    "xlsr_freeze_layers": 12,
    "backend": "ModifiedAASIST",
    "hidden_dim": 160,
    "emb_dim": 128,
    "num_heads": 4,
    "num_gat_layers": 2,
    "num_spectral_nodes": 32,
