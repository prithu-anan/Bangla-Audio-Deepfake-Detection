{
  "model": "BanglaDeepfakeDetector",
  "architecture": {
    "frontend": "microsoft/wavlm-large",
    "wavlm_freeze_layers": 12,
    "backend": "ModifiedAASIST",
    "hidden_dim": 160,
    "emb_dim": 128,
    "num_heads": 4,
    "num_gat_layers": 2,
    "num_spectral_nodes": 32,
